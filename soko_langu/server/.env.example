# Railway deployment — set these in Railway dashboard
# -------------------------------------------------
# Required:
MONGIKE_API_KEY=mk_your_mongike_api_key_here
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your_project_id",...}
ADMIN_SECRET=your_admin_secret_here
WEBHOOK_SECRET=your_webhook_secret_here
WEBHOOK_URL=https://your-app.up.railway.app/api/webhook

# Optional (Railway sets PORT automatically):
PORT=3000

# SMTP for OTP emails (uses Gmail App Password):
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=Your App <your_email@gmail.com>
SMTP_SECURE=false

# Escrow config:
ESCROW_AUTO_RELEASE_DAYS=14

# Fraud prevention:
MAX_DAILY_SALE_AMOUNT=5000000

# Meseji SMS (server-side API key — never expose on client):
MESEJI_API_KEY=zs_your_meseji_api_key_here
MESEJI_SENDER_ID=YOUR_SENDER_ID

# Cloudinary (for signed uploads — get from Cloudinary Dashboard):
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# ─── How to deploy on Railway ───
# 1. Push this folder to a GitHub repo
# 2. In Railway, click "New Project" → "Deploy from GitHub repo"
# 3. Add all env vars above in Railway dashboard (settings → variables)
# 4. For FIREBASE_SERVICE_ACCOUNT_JSON, paste the entire JSON (single line, no newlines)
# 5. Railway will auto-detect Node.js and run `npm start` (node index.js)
# 6. The /health endpoint confirms the server is running
