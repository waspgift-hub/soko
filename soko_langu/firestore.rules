rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@soko-langu.com' ||
        request.auth.token.email == 'admin@soko-vibe.com' ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
        )
      );
    }

    function notSuspended() {
      return isSignedIn() && (
        !exists(/databases/$(database)/documents/users/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isSuspended != true
      );
    }

    // ─── USERS ──────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();

      match /following/{followingId} {
        allow read, write: if isOwner(userId);
      }

      match /followers/{followerId} {
        allow read, write: if isOwner(userId);
      }

      match /admin_withdrawals/{wdId} {
        allow read, write: if isOwner(userId);
      }

      match /cart/{itemId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ─── PRODUCTS ───────────────────────────────────────────
    match /products/{productId} {
      allow read: if true;
      allow create: if isSignedIn() && notSuspended() && request.resource.data.sellerId == request.auth.uid;
      allow update: if (isSignedIn() && notSuspended() && resource.data.sellerId == request.auth.uid) || isAdmin();
      allow delete: if (isSignedIn() && notSuspended() && resource.data.sellerId == request.auth.uid) || isAdmin();

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && notSuspended() && request.resource.data.userId == request.auth.uid;
        allow update: if isSignedIn() && notSuspended() && (
          resource.data.userId == request.auth.uid ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['replyCount'])
        );
        allow delete: if isSignedIn() && notSuspended() && resource.data.userId == request.auth.uid;

        match /replies/{replyId} {
          allow read: if true;
          allow create: if isSignedIn() && notSuspended() && request.resource.data.userId == request.auth.uid;
          allow update: if isSignedIn() && notSuspended() && resource.data.userId == request.auth.uid;
          allow delete: if isSignedIn() && notSuspended() && resource.data.userId == request.auth.uid;
        }
      }
    }

    // ─── CATEGORIES ─────────────────────────────────────────
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // ─── ORDERS / TRANSACTIONS ──────────────────────────────
    match /orders/{orderId} {
      allow read: if isSignedIn() && (
        resource.data.buyerId == request.auth.uid ||
        resource.data.sellerId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isSignedIn() && request.resource.data.buyerId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.buyerId == request.auth.uid ||
        resource.data.sellerId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /transactions/{txId} {
      allow read: if isSignedIn() && (
        resource.data.buyerId == request.auth.uid ||
        resource.data.sellerId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isSignedIn() && request.resource.data.buyerId == request.auth.uid;
      allow update: if isSignedIn() && (
        (resource.data.buyerId == request.auth.uid && (
          resource.data.status == 'pending' ||
          resource.data.status == 'awaiting_payment' ||
          resource.data.status == 'failed'
        )) ||
        resource.data.sellerId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ─── CARTS ──────────────────────────────────────────────
    match /carts/{cartId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;

      match /items/{itemId} {
        allow read: if isSignedIn() && get(/databases/$(database)/documents/carts/$(cartId)).data.userId == request.auth.uid;
        allow write: if isSignedIn() && get(/databases/$(database)/documents/carts/$(cartId)).data.userId == request.auth.uid;
      }
    }

    // ─── CONVERSATIONS & MESSAGES ───────────────────────────
    match /conversations/{convId} {
      allow read, write: if isSignedIn();

      match /messages/{msgId} {
        allow read, write: if isSignedIn();
      }
    }

    // ─── CHATS (legacy) ─────────────────────────────────────
    match /chats/{chatId} {
      allow read, write: if isSignedIn();

      match /messages/{msgId} {
        allow read, write: if isSignedIn();
      }
    }

    // ─── CHAT ROOMS ─────────────────────────────────────────
    match /chat_rooms/{roomId} {
      allow read, write: if isSignedIn();

      match /messages/{msgId} {
        allow read, write: if isSignedIn();
      }
    }

    // ─── FLASH SALES ────────────────────────────────────────
    match /flash_sales/{saleId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.sellerId == request.auth.uid;
      allow update: if isAdmin() || (isSignedIn() && resource.data.sellerId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ─── NOTIFICATIONS ──────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn()
        && (request.resource.data.userId == request.auth.uid || isAdmin())
        && request.resource.data.keys().hasAll(['title', 'body', 'userId'])
        && request.resource.data.title is string
        && request.resource.data.body is string;
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ─── REVIEWS ────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && notSuspended() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && notSuspended() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && notSuspended() && resource.data.userId == request.auth.uid;
    }

    // ─── AD VIEWS ───────────────────────────────────────────
    match /ad_views/{adViewId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // ─── ADMIN ADMOB EARNINGS ───────────────────────────────
    match /admob_earnings/{docId} {
      allow read, write: if isAdmin();
    }

    // ─── ADMIN NOTIFICATIONS LOG ──────────────────────────
    match /admin_notifications/{docId} {
      allow read, write: if isAdmin();
    }

    // ─── APP SETTINGS (maintenance mode, etc.) ─────────────
    match /app_settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── PRICE DROPS ────────────────────────────────────────
    match /price_drops/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // ─── ADMIN WITHDRAWALS ──────────────────────────────────
    match /admin_withdrawals/{wdId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ─── GROUPS ─────────────────────────────────────────────
    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();

      match /messages/{msgId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    // ─── STATUSES ───────────────────────────────────────────
    match /statuses/{statusId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ─── TRANSACTIONS (server-managed, client read-only) ────
    match /transactions/{txId} {
      allow read: if isSignedIn() && (
        resource.data.buyerId == request.auth.uid ||
        resource.data.sellerId == request.auth.uid ||
        isAdmin()
      );
      // For now, allow writes for backward compat (webhook already writes server-side)
      allow write: if isSignedIn();
    }

    // ─── REVENUE TRANSACTIONS ───────────────────────────────
    match /revenue_transactions/{txId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ─── WITHDRAWALS ────────────────────────────────────────
    match /withdrawals/{wdId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // ─── ADMIN EXPORTS ──────────────────────────────────────
    match /admin_exports/{exportId} {
      allow read, write: if isAdmin();
    }

    // ─── REPORTS ─────────────────────────────────────────────
    match /reports/{reportId} {
      allow read: if isSignedIn() && (
        resource.data.reporterId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isSignedIn() && notSuspended();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── FRAUD ALERTS ───────────────────────────────────────
    match /fraud_alerts/{alertId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // ─── AUDIT LOG ──────────────────────────────────────────
    match /audit_log/{logId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
