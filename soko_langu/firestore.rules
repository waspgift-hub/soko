rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // ─── USERS ──────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if isSignedIn() && request.auth.uid == userId;

      match /following/{followingId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }

      match /followers/{followerId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }

      match /admin_withdrawals/{wdId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // ─── PRODUCTS ───────────────────────────────────────────
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isSignedIn();

      match /comments/{commentId} {
        allow read: if true;
        allow create, update, delete: if isSignedIn();

        match /replies/{replyId} {
          allow read, write: if isSignedIn();
        }
      }
    }

    // ─── CATEGORIES ─────────────────────────────────────────
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // ─── ORDERS ─────────────────────────────────────────────
    match /orders/{orderId} {
      allow read, write: if isSignedIn();
    }

    // ─── CARTS ──────────────────────────────────────────────
    match /carts/{cartId} {
      allow read, write: if isSignedIn();

      match /items/{itemId} {
        allow read, write: if isSignedIn();
      }
    }

    // ─── CONVERSATIONS & MESSAGES ───────────────────────────
    match /conversations/{convId} {
      allow read, write: if isSignedIn();

      match /messages/{msgId} {
        allow read, write: if isSignedIn();
      }
    }

    // ─── CHATS (legacy) ─────────────────────────────────────
    match /chats/{chatId} {
      allow read, write: if isSignedIn();

      match /messages/{msgId} {
        allow read, write: if isSignedIn();
      }
    }

    // ─── CALLS ──────────────────────────────────────────────
    match /calls/{callId} {
      allow read, write: if isSignedIn();
    }

    // ─── NOTIFICATIONS ──────────────────────────────────────
    match /notifications/{notifId} {
      allow read, write: if isSignedIn();
    }

    // ─── REVIEWS ────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // ─── AD VIEWS ───────────────────────────────────────────
    match /ad_views/{adViewId} {
      allow read, write: if isSignedIn();
    }

    // ─── LIVE STREAMS ───────────────────────────────────────
    match /live_streams/{streamId} {
      allow read: if true;
      allow write: if isSignedIn();

      match /{subcollection}/{docId} {
        allow read, write: if isSignedIn();
      }
    }

    // ─── LIVE GIFTS ─────────────────────────────────────────
    match /live_gifts/{giftId} {
      allow read, write: if isSignedIn();
    }

    // ─── VIEWER AD VIEWS & PAYOUTS ─────────────────────────
    match /viewer_ad_views/{viewId} {
      allow read, write: if isSignedIn();
    }
    match /admin_ad_revenue/{revenueId} {
      allow read, write: if isSignedIn();
    }
    match /viewer_payouts/{payoutId} {
      allow read, write: if isSignedIn();
    }
    match /viewer_soft_payouts/{payoutId} {
      allow read, write: if isSignedIn();
    }

    // ─── STREAMER WITHDRAWALS ───────────────────────────────
    match /streamer_withdrawals/{wdId} {
      allow read, write: if isSignedIn();
    }

    // ─── ADMIN WITHDRAWALS (top-level) ─────────────────────
    match /admin_withdrawals/{wdId} {
      allow read, write: if isSignedIn();
    }

    // ─── GROUPS ─────────────────────────────────────────────
    match /groups/{groupId} {
      allow read, write: if isSignedIn();

      match /messages/{msgId} {
        allow read, write: if isSignedIn();
      }
    }

    // ─── WALLETS & TRANSACTIONS ─────────────────────────────
    match /wallets/{walletId} {
      allow read, write: if isSignedIn();
    }

    match /revenue_transactions/{txId} {
      allow read, write: if isSignedIn();
    }

    match /transactions/{txId} {
      allow read, write: if isSignedIn();
    }

    // ─── WITHDRAWALS ────────────────────────────────────────
    match /withdrawals/{wdId} {
      allow read, write: if isSignedIn();
    }

    // ─── ADMIN EXPORTS ──────────────────────────────────────
    match /admin_exports/{exportId} {
      allow read, write: if isSignedIn();
    }

    // ─── AUDIT LOG ──────────────────────────────────────────
    match /audit_log/{logId} {
      allow read, write: if isSignedIn();
    }
  }
}
